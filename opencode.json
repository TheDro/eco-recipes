{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "ls*": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "npm run build*": "allow",
      "npm run dev*": "allow",
      "npm run preview*": "allow",
      "npm install*": "allow",
    }
  }
}
